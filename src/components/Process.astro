---
const steps = [
  { num: "01", title: "You call", text: "Reach Daniel directly at 865-851-5002. Tell us what's going on — a leak, a storm, or just a roof that's seen better days.", duration: "Same day" },
  { num: "02", title: "We inspect", text: "We come out, climb up, and run a free 21-point inspection. You get photos and a written, flat-rate quote — no pressure.", duration: "Free" },
  { num: "03", title: "We install", text: "Crew shows up on time, protects your landscaping, tears off and installs cleanly. Backed by our lifetime no-leak guarantee.", duration: "1–3 days" },
];
---

<section class="process" id="process">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">How it works</span>
      <h2>Three simple steps. Zero pressure.</h2>
      <p>From your first call to the final walk-through, you'll know exactly what's happening and exactly what it costs.</p>
    </div>

    <div class="grid grid--3 process__grid">
      {steps.map((s) => (
        <div class="step card">
          <span class="step__num">{s.num}</span>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
          <span class="step__duration">{s.duration}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process { background: var(--color-surface); }
  .step {
    position: relative;
    padding-top: 40px;
  }
  .step__num {
    position: absolute;
    top: 24px;
    right: 28px;
    font-size: 56px;
    font-weight: 900;
    color: var(--color-accent-soft);
    line-height: 1;
    letter-spacing: -0.05em;
  }
  .step h3 { margin-bottom: 8px; }
  .step p { font-size: 15px; margin-bottom: 16px; }
  .step__duration {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 999px;
  }
</style>
