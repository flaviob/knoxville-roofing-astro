---
import { site } from "../data/site";
const { business } = site;
const stats = [
  { value: `${business.yearsInBusiness}+`, label: "Years roofing East TN" },
  { value: business.totalFiveStarReviews, label: "Five-star reviews" },
  { value: business.googleReviews, label: "Google reviews" },
  { value: "Lifetime", label: "No-leak guarantee" },
];
---

<section class="stats">
  <div class="container">
    <div class="stats__grid">
      {stats.map((s) => (
        <div class="stats__item">
          <strong>{s.value}</strong>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--color-primary);
    color: #fff;
    padding: 64px 0;
  }
  .stats__grid {
    display: grid;
    gap: 32px;
    grid-template-columns: repeat(2, 1fr);
    text-align: center;
  }
  @media (min-width: 720px) {
    .stats__grid { grid-template-columns: repeat(4, 1fr); }
  }
  .stats__item strong {
    display: block;
    font-size: clamp(2.4rem, 5vw, 3.2rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 8px;
  }
  .stats__item span {
    display: block;
    font-size: 14px;
    color: #94a3b8;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
</style>
