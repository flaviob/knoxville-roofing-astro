---
import { site } from "../data/site";
const featured = site.services.filter((s) => s.featured);
---

<section class="services" id="services">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">What we do</span>
      <h2>Roofing built for East Tennessee weather</h2>
      <p>From the ice storms in Anderson County to the wind off the Smokies, we build roofs that hold up. Every replacement carries our lifetime no-leak guarantee.</p>
    </div>

    <div class="grid grid--2 services__grid">
      {featured.map((s) => (
        <a href={`/services/#${s.slug}`} class="service card">
          <div class="service__icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 22 L20 8 L35 22" />
              <path d="M10 22 L10 34 L30 34 L30 22" />
              <path d="M16 34 L16 26 L24 26 L24 34" />
            </svg>
          </div>
          <h3>{s.name}</h3>
          <p>{s.blurb}</p>
          <span class="service__cta">Learn more →</span>
        </a>
      ))}
    </div>

    <div class="services__more">
      <span>Also offering:</span>
      {site.services.filter((s) => !s.featured).map((s) => (
        <a href={`/services/#${s.slug}`} class="services__pill">{s.name}</a>
      ))}
    </div>
  </div>
</section>

<style>
  .services { background: var(--color-bg); }
  .service {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-ink);
    padding: 32px;
  }
  .service__icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .service h3 { color: var(--color-primary); margin-bottom: 8px; }
  .service p { color: var(--color-ink-soft); font-size: 15px; margin-bottom: 16px; flex: 1; }
  .service__cta {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 15px;
  }
  .services__more {
    margin-top: 40px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .services__more > span {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink-muted);
    margin-right: 8px;
  }
  .services__pill {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    text-decoration: none;
  }
  .services__pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
