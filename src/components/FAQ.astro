---
import { site } from "../data/site";
const { faqs, business } = site;
---

<section class="faq" id="faq">
  <div class="container container--narrow">
    <div class="section-head">
      <span class="eyebrow">FAQ</span>
      <h2>Knoxville roof questions, answered</h2>
      <p>Don't see your question? Call Daniel at <a href={business.phoneHref}>{business.phone}</a> — he'll answer it himself.</p>
    </div>

    <div class="faq__list">
      {faqs.map((f, i) => (
        <details class="faq__item" open={i === 0}>
          <summary>
            <span>{f.q}</span>
            <span class="faq__chevron" aria-hidden="true">+</span>
          </summary>
          <div class="faq__body"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq { background: var(--color-bg); }
  .faq__list { display: flex; flex-direction: column; gap: 12px; }
  .faq__item {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 0;
    overflow: hidden;
    transition: border-color 140ms ease;
  }
  .faq__item[open] { border-color: var(--color-line-strong); }
  .faq__item summary {
    list-style: none;
    cursor: pointer;
    padding: 22px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 17px;
    font-weight: 700;
    color: var(--color-primary);
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__chevron {
    display: inline-flex;
    width: 28px; height: 28px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-surface-alt);
    color: var(--color-accent);
    font-size: 18px;
    font-weight: 800;
    transition: transform 200ms ease;
    flex-shrink: 0;
  }
  .faq__item[open] .faq__chevron { transform: rotate(45deg); }
  .faq__body { padding: 0 24px 22px; }
  .faq__body p { margin: 0; color: var(--color-ink-soft); font-size: 16px; }
</style>
